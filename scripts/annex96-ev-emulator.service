[Unit]
Description=Annex96 EV Emulator
After=network.target

[Service]
Type=simple
User=pi
Group=pi
SupplementaryGroups=gpio dialout
WorkingDirectory=/home/pi/annex96-car-emulator
ExecStart=/home/pi/annex96-car-emulator/.venv/bin/python -m daemon.main
Restart=on-failure
RestartSec=2
Environment=PLC_SERIAL_PORT=/dev/serial0
Environment=PLC_HTTP_PORT=8081
Environment=LOG_LEVEL=INFO

[Install]
WantedBy=multi-user.target