[Unit]
Description=Annex96 EV Emulator
After=network.target

[Service]
Type=simple
User=openemulator
WorkingDirectory=/home/openemulator/annex96-car-emulator
ExecStart=/home/openemulator/annex96-car-emulator/.venv/bin/python -m daemon.main
Restart=on-failure
Environment=PLC_SERIAL_PORT=/dev/serial0
Environment=PLC_HTTP_PORT=8081

[Install]
WantedBy=multi-user.target
